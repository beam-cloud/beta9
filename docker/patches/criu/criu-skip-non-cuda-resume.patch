@@ -88,0 +100,160 @@ static int add_pid_to_buf(struct list_head *pid_buf, int pid, cuda_task_state_t
+static int write_full(int fd, const void *buf, size_t size)
+{
+	const char *cursor = buf;
+
+	while (size > 0) {
+		ssize_t written = write(fd, cursor, size);
+
+		if (written < 0) {
+			if (errno == EINTR)
+				continue;
+			return -1;
+		}
+		if (written == 0) {
+			errno = EIO;
+			return -1;
+		}
+		cursor += written;
+		size -= written;
+	}
+
+	return 0;
+}
+
+static int read_full(int fd, void *buf, size_t size)
+{
+	char *cursor = buf;
+
+	while (size > 0) {
+		ssize_t bytes_read = read(fd, cursor, size);
+
+		if (bytes_read < 0) {
+			if (errno == EINTR)
+				continue;
+			return -1;
+		}
+		if (bytes_read == 0) {
+			errno = EIO;
+			return -1;
+		}
+		cursor += bytes_read;
+		size -= bytes_read;
+	}
+
+	return 0;
+}
