+static void finish_cuda_pid_image(int dump_ret)
+{
+	struct pid_info *info;
+	int image_dir_fd = criu_get_image_dir();
+	int fd = -1;
+	int saved_errno = EIO;
+	size_t count = 0;
+	bool published = false;
+
+	if (dump_ret || !plugin_added_to_inventory)
+		return;
+	unlinkat(image_dir_fd, CUDA_PID_IMAGE, 0);
+	unlinkat(image_dir_fd, CUDA_PID_IMAGE_TMP, 0);
+	fd = openat(image_dir_fd, CUDA_PID_IMAGE_TMP,
+		    O_WRONLY | O_CREAT | O_TRUNC | O_CLOEXEC, 0600);
+	if (fd < 0)
+		goto out;
+
+	list_for_each_entry(info, &cuda_pids, list) {
+		pid_t virt_pid = pid_to_virt(info->pid);
+
+		if (virt_pid <= 0 || count == CUDA_PID_IMAGE_MAX_ENTRIES) {
+			errno = EINVAL;
+			goto out;
+		}
+		if (write_full(fd, &virt_pid, sizeof(virt_pid)))
+			goto out;
+		count++;
+	}
+	if (count == 0) {
+		errno = EINVAL;
+		goto out;
+	}
+	if (fsync(fd))
+		goto out;
+	if (close(fd)) {
+		fd = -1;
+		goto out;
+	}
+	fd = -1;
+	if (renameat(image_dir_fd, CUDA_PID_IMAGE_TMP, image_dir_fd, CUDA_PID_IMAGE))
+		goto out;
+	published = true;
+
+out:
+	saved_errno = errno;
+	if (fd >= 0)
+		close(fd);
+	if (!published)
+		unlinkat(image_dir_fd, CUDA_PID_IMAGE_TMP, 0);
+	if (published)
+		pr_info("saved %zu CUDA process IDs\n", count);
+	else {
+		errno = saved_errno;
+		pr_perror("failed to save CUDA process metadata; restore will use compatibility mode");
+	}
+}
+
+static int load_cuda_pid_image(void)
+{
+	struct stat st;
+	pid_t *pids = NULL;
+	int fd;
+	size_t count;
+	size_t i;
+	int ret = -1;
+
+	fd = openat(criu_get_image_dir(), CUDA_PID_IMAGE, O_RDONLY | O_CLOEXEC);
+	if (fd < 0)
+		return errno == ENOENT ? 0 : -1;
+	if (fstat(fd, &st) || st.st_size <= 0 || st.st_size % sizeof(*pids) != 0 ||
+	    st.st_size > CUDA_PID_IMAGE_MAX_ENTRIES * sizeof(*pids)) {
+		errno = EINVAL;
+		goto out;
+	}
+	count = st.st_size / sizeof(*pids);
+	pids = xmalloc(st.st_size);
+	if (pids == NULL || read_full(fd, pids, st.st_size))
+		goto out;
+	for (i = 0; i < count; i++) {
+		if (pids[i] <= 0) {
+			errno = EINVAL;
+			goto out;
+		}
+	}
+
+	restore_cuda_pids = pids;
+	restore_cuda_pid_count = count;
+	restore_cuda_pid_filter = true;
+	pids = NULL;
+	pr_info("loaded %zu CUDA process IDs\n", count);
+	ret = 0;
+out:
+	if (pids != NULL)
+		xfree(pids);
+	close(fd);
+	return ret;
+}
+
+static bool is_cuda_restore_pid(pid_t real_pid)
+{
+	pid_t virt_pid = pid_to_virt(real_pid);
+	size_t i;
+
+	if (!restore_cuda_pid_filter || virt_pid <= 0)
+		return true;
+	for (i = 0; i < restore_cuda_pid_count; i++) {
+		if (restore_cuda_pids[i] == virt_pid)
+			return true;
+	}
+
+	return false;
+}
