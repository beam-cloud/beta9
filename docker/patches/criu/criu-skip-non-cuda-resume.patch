+static int load_beam_network_map(void)
+{
+	char version[8], old_v4[INET_ADDRSTRLEN], new_v4[INET_ADDRSTRLEN];
+	char old_v6[INET6_ADDRSTRLEN], new_v6[INET6_ADDRSTRLEN];
+	char buffer[BEAM_NETWORK_MAP_BUFFER_SIZE];
+	ssize_t bytes_read;
+	int fd;
+
+	if (beam_network_map_status != -2)
+		return beam_network_map_status;
+
+	fd = open(BEAM_NETWORK_MAP_FILE, O_RDONLY | O_CLOEXEC);
+	if (fd < 0) {
+		if (errno == ENOENT) {
+			beam_network_map_status = 0;
+			return 0;
+		}
+		pr_perror("Can't open Beam network map");
+		beam_network_map_status = -1;
+		return -1;
+	}
+
+	bytes_read = read(fd, buffer, sizeof(buffer) - 1);
+	close(fd);
+	if (bytes_read <= 0) {
+		if (bytes_read == 0)
+			errno = EINVAL;
+		pr_perror("Can't read Beam network map");
+		beam_network_map_status = -1;
+		return -1;
+	}
+	buffer[bytes_read] = '\0';
+
+	if (sscanf(buffer, "%7s %15s %15s %45s %45s", version, old_v4, new_v4,
+		   old_v6, new_v6) != 5 ||
+	    strcmp(version, BEAM_NETWORK_MAP_VERSION) != 0 ||
+	    inet_pton(AF_INET, old_v4, &beam_network_map.old_v4) != 1 ||
+	    inet_pton(AF_INET, new_v4, &beam_network_map.new_v4) != 1 ||
+	    inet_pton(AF_INET6, old_v6, &beam_network_map.old_v6) != 1 ||
+	    inet_pton(AF_INET6, new_v6, &beam_network_map.new_v6) != 1) {
+		errno = EINVAL;
+		pr_perror("Invalid Beam network map");
+		beam_network_map_status = -1;
+		return -1;
+	}
+
+	beam_network_map_status = 1;
+	close_external_tcp = 1;
+	pr_info("Container socket addresses will be remapped from %s to %s\n", old_v4, new_v4);
+	return 1;
+}
+
+static bool remap_beam_address(int family, uint32_t *address)
+{
+	struct in6_addr *address_v6;
+
+	if (family == AF_INET) {
+		if (memcmp(address, &beam_network_map.old_v4, sizeof(beam_network_map.old_v4)) != 0)
+			return false;
+		memcpy(address, &beam_network_map.new_v4, sizeof(beam_network_map.new_v4));
+		return true;
+	}
+	if (family != AF_INET6)
+		return false;
+
+	address_v6 = (struct in6_addr *)address;
+	if (memcmp(address_v6, &beam_network_map.old_v6, sizeof(*address_v6)) == 0) {
+		memcpy(address_v6, &beam_network_map.new_v6, sizeof(*address_v6));
+		return true;
+	}
+	if (IN6_IS_ADDR_V4MAPPED(address_v6) &&
+	    memcmp(&address_v6->s6_addr[12], &beam_network_map.old_v4,
+		   sizeof(beam_network_map.old_v4)) == 0) {
+		memcpy(&address_v6->s6_addr[12], &beam_network_map.new_v4,
+		       sizeof(beam_network_map.new_v4));
+		return true;
+	}
+	return false;
+}
+
+static int remap_beam_socket_addresses(InetSkEntry *ie)
+{
+	bool remapped = false;
+	int status = load_beam_network_map();
+
+	if (status <= 0)
+		return status;
+	if (ie->family == AF_INET && ie->n_src_addr >= PB_ALEN_INET &&
+	    ie->n_dst_addr >= PB_ALEN_INET) {
+		remapped |= remap_beam_address(ie->family, ie->src_addr);
+		remapped |= remap_beam_address(ie->family, ie->dst_addr);
+	} else if (ie->family == AF_INET6 && ie->n_src_addr == PB_ALEN_INET6 &&
+		   ie->n_dst_addr == PB_ALEN_INET6) {
+		remapped |= remap_beam_address(ie->family, ie->src_addr);
+		remapped |= remap_beam_address(ie->family, ie->dst_addr);
+	}
+	if (remapped)
+		pr_info("Remapped container address for socket id %x\n", ie->id);
+	return 0;
+}
+
+static bool beam_address_is_local(int family, uint32_t *address)
+{
+	const unsigned char *address_v4;
+	struct in6_addr *address_v6;
+
+	if (family == AF_INET) {
+		address_v4 = (const unsigned char *)address;
+		return address_v4[0] == 127 ||
+		       memcmp(address, &beam_network_map.new_v4,
+			      sizeof(beam_network_map.new_v4)) == 0;
+	}
+	if (family != AF_INET6)
+		return false;
+
+	address_v6 = (struct in6_addr *)address;
+	if (IN6_IS_ADDR_LOOPBACK(address_v6) ||
+	    memcmp(address_v6, &beam_network_map.new_v6, sizeof(*address_v6)) == 0)
+		return true;
+	if (!IN6_IS_ADDR_V4MAPPED(address_v6))
+		return false;
+
+	address_v4 = &address_v6->s6_addr[12];
+	return address_v4[0] == 127 ||
+	       memcmp(address_v4, &beam_network_map.new_v4,
+		      sizeof(beam_network_map.new_v4)) == 0;
+}
+
+static bool should_close_external_tcp(InetSkEntry *ie)
+{
+	size_t address_size;
+
+	if (!tcp_connection(ie))
+		return false;
+	if (close_external_tcp < 0) {
+		close_external_tcp = faccessat(get_service_fd(IMG_FD_OFF),
+					       BEAM_CLOSE_EXTERNAL_TCP_MARKER, F_OK, 0) == 0;
+		if (close_external_tcp)
+			pr_info("External TCP connections will be restored closed\n");
+	}
+	if (!close_external_tcp)
+		return false;
+	if (beam_network_map_status == 1)
+		return !beam_address_is_local(ie->family, ie->src_addr) ||
+		       !beam_address_is_local(ie->family, ie->dst_addr);
+
+	if (ie->family == AF_INET && ie->n_src_addr >= PB_ALEN_INET &&
+	    ie->n_dst_addr >= PB_ALEN_INET)
+		address_size = PB_ALEN_INET * sizeof(*ie->src_addr);
+	else if (ie->family == AF_INET6 && ie->n_src_addr == PB_ALEN_INET6 &&
+		 ie->n_dst_addr == PB_ALEN_INET6)
+		address_size = PB_ALEN_INET6 * sizeof(*ie->src_addr);
+	else
+		return false;
+
+	return memcmp(ie->src_addr, ie->dst_addr, address_size) != 0;
+}
